    {
        "id": "9d0b6275ed210916",
        "type": "function",
        "z": "b2d257ff0cc80c0a",
        "name": "Processar pets",
        "func": "var pets = msg.payload;\nif (!pets || pets.length === 0) {\n  flow.set('estado_leds', {});\n  flow.set('nomes_ativos', []);\n  return [{payload: '0', topic: 'coleira/dias'},{payload: []},{payload: 0},{payload: 'Nenhum animal cadastrado'},null,null];\n}\n\nvar resumo = [];\nvar contagem = {roxo:0, verde:0, amarelo:0, vermelho:0};\nvar estadoAnterior = flow.get('estado_leds') || {};\nvar nomesAtivos = [];\nvar logMsgs = [];\n\nfor (var i = 0; i < pets.length; i++) {\n  var p = pets[i];\n  var dias = parseInt(p.dias_restantes);\n  var led = '';\n  if (dias <= 1) led = 'roxo';\n  else if (dias <= 5) led = 'verde';\n  else if (dias <= 15) led = 'amarelo';\n  else led = 'vermelho';\n  contagem[led]++;\n  nomesAtivos.push(p.nome);\n  resumo.push({nome: p.nome, especie: p.especie, tutor: p.tutor, dias: dias < 0 ? 'ATRASADO' : String(dias) + ' dias', led: led, data: p.data_fmt});\n  if (estadoAnterior[p.nome] !== led) {\n    logMsgs.push({topic: \"INSERT INTO log_alertas (pet_id, pet_nome, dias_restantes, status_led) SELECT id, '\" + p.nome + \"', \" + (dias < 0 ? 0 : dias) + \", '\" + led + \"' FROM pets WHERE nome='\" + p.nome + \"' LIMIT 1\"});\n    estadoAnterior[p.nome] = led;\n  }\n}\n\n// Remove do estado pets que foram deletados do banco\nvar estadoLimpo = {};\nfor (var j = 0; j < nomesAtivos.length; j++) {\n  estadoLimpo[nomesAtivos[j]] = estadoAnterior[nomesAtivos[j]];\n}\nflow.set('estado_leds', estadoLimpo);\nflow.set('nomes_ativos', nomesAtivos);\n\nvar diasNum = parseInt(pets[0].dias_restantes);\nvar critico = resumo.find(function(p){ return p.led === 'roxo'; });\nvar txtContagem = '✅ Longe: ' + contagem.vermelho + '  |  ⏰ 15 dias: ' + contagem.amarelo + '  |  ⚠️ 5 dias: ' + contagem.verde + '  |  🚨 URGENTE: ' + contagem.roxo;\nvar alertaMsg = null;\nif (critico) alertaMsg = {payload: '⚨️ URGENTE: ' + critico.nome + ' - consulta em 1 dia!'};\nreturn [{payload: String(diasNum < 0 ? 0 : diasNum), topic: 'coleira/dias'},{payload: resumo},{payload: diasNum < 0 ? 0 : diasNum},{payload: txtContagem},alertaMsg,logMsgs.length > 0 ? logMsgs : null];",
        "outputs": 6,
