    {
        "id": "fn_registrar_historico",
        "type": "function",
        "z": "b2d257ff0cc80c0a",
        "name": "Montar INSERT historico",
        "func": "var d = msg.payload;\nvar nome = (d.nome || '').replace(/'/g,'').trim();\nvar obs = (d.observacoes || '').replace(/'/g,'').trim();\nvar dataConsRaw = (d.data_consulta || '').trim();\nvar dataProxRaw = (d.proxima_consulta || '').trim();\n\nfunction converterData(raw) {\n  if (raw.indexOf('/') >= 0) {\n    var p = raw.split('/');\n    if (p.length === 3) return p[2] + '-' + p[1] + '-' + p[0];\n  }\n  return raw;\n}\n\nvar dataConsSQL = converterData(dataConsRaw);\nvar dataProxSQL = converterData(dataProxRaw);\n\nif (!nome || !dataConsSQL || !dataProxSQL) {\n  node.warn('Campos obrigatorios nao preenchidos');\n  return null;\n}\n\nflow.set('historico_nome', nome);\nflow.set('historico_prox', dataProxSQL);\n\nmsg.topic = \"INSERT INTO historico_consultas (pet_id, data_consulta, observacoes) SELECT id, '\" + dataConsSQL + \"', '\" + obs + \"' FROM pets WHERE nome='\" + nome + \"' LIMIT 1\";\nreturn msg;",
        "outputs": 1,
