        "id": "query_historico",
        "type": "function",
        "z": "b2d257ff0cc80c0a",
        "name": "Query historico",
        "func": "msg.topic = \"SELECT p.nome, p.especie, DATE_FORMAT(h.data_consulta, '%d/%m/%Y') AS data_consulta, h.observacoes, DATE_FORMAT(h.registrado_em, '%d/%m/%Y %H:%i') AS registrado_em FROM historico_consultas h INNER JOIN pets p ON p.id = h.pet_id ORDER BY h.data_consulta DESC LIMIT 50\";\nreturn msg;",
