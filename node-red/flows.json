        "type": "function",
        "z": "b2d257ff0cc80c0a",
        "name": "Converter data e INSERT",
        "func": "var d = msg.payload;\nvar nome = (d.nome || '').replace(/'/g,'');\nvar especie = (d.especie || '').replace(/'/g,'');\nvar tutor = (d.tutor || '').replace(/'/g,'');\nvar dataRaw = (d.proxima_consulta || '').trim();\nvar dataSQL = '';\nif (dataRaw.indexOf('/') >= 0) {\n  var partes = dataRaw.split('/');\n  if (partes.length === 3) dataSQL = partes[2] + '-' + partes[1] + '-' + partes[0];\n} else { dataSQL = dataRaw; }\nif (!nome || !especie || !tutor || !dataSQL) { node.warn('Campos obrigatorios'); return null; }\nmsg.topic = \"INSERT INTO pets (nome, especie, tutor, proxima_consulta) VALUES ('\" + nome + \"', '\" + especie + \"', '\" + tutor + \"', '\" + dataSQL + \"')\";\nreturn msg;",
